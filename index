    function applyTranslations(lang){
      document.documentElement.lang = lang;
      document.querySelectorAll('[data-i18n]').forEach(function(el){
        const key = el.getAttribute('data-i18n');
        if(i18n[lang] && i18n[lang][key] !== undefined){
          el.textContent = i18n[lang][key];
        }
      });
      document.querySelectorAll('[data-i18n-placeholder]').forEach(function(el){
        const key = el.getAttribute('data-i18n-placeholder');
        if(i18n[lang] && i18n[lang][key] !== undefined){
          el.setAttribute('placeholder', i18n[lang][key]);
        }
      });
      document.querySelectorAll('[data-i18n-meta]').forEach(function(el){
        const key = el.getAttribute('data-i18n-meta');
        if(i18n[lang] && i18n[lang][key] !== undefined){
          el.setAttribute('content', i18n[lang][key]);
        }
      });
      document.querySelectorAll('[data-lang-btn]').forEach(function(btn){
        btn.classList.toggle('active', btn.getAttribute('data-lang-btn') === lang);
      });
    }

    function toggleMobileNav(forceState){
      const nav = document.getElementById('mobile-nav');
      const nextState = typeof forceState === 'boolean'
        ? forceState
        : nav.style.display === 'none' || nav.style.display === '' ;
      nav.style.display = nextState ? 'block' : 'none';
    }

    function setLanguage(lang){
      localStorage.setItem('collectividual_lang', lang);
      applyTranslations(lang);
    }

    function showPage(name){
      document.querySelectorAll('.page').forEach(function(page){
        page.classList.remove('active');
      });
      var target = document.getElementById(name + '-page');
      if(target){
        target.classList.add('active');
        window.scrollTo({ top: 0, behavior: 'smooth' });
      }
    }

    function goToSection(sectionId){
      showPage('home');
      setTimeout(function(){
        var el = document.getElementById(sectionId);
        if(el){
          el.scrollIntoView({ behavior: 'smooth', block: 'start' });
        }
      }, 30);
    }

    const savedLang = localStorage.getItem('collectividual_lang');
    const initialLang = savedLang || 'en';
    applyTranslations(initialLang);

    if (window.location.search.includes('subscribed=true')) {
      document.getElementById('success-message').style.display = 'block';
    }
  </script>

    <script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
    <script>

    (function () {
      const SUPABASE_URL = "https://qngyhxxxvaueyxqtwkzc.supabase.co";
      const SUPABASE_ANON_KEY = "sb_publishable_XDgGxv0CJ2Lr2DyVWlLTVA_E_49_J1L";

      if (!window.supabase || !SUPABASE_URL || !SUPABASE_ANON_KEY) {
        console.warn("Collectividual membership embed is waiting for real Supabase credentials.");
        return;
      }

      const supabaseClient = window.supabase.createClient(SUPABASE_URL, SUPABASE_ANON_KEY);

      const tabs = Array.from(document.querySelectorAll("[data-auth-tab]"));
      const guestView = document.getElementById("clv-auth-guest-view");
      const memberView = document.getElementById("clv-auth-member-view");
      const form = document.getElementById("clv-auth-form");
      const nameRow = document.getElementById("clv-auth-name-row");
      const nameInput = document.getElementById("clv-auth-name");
      const emailInput = document.getElementById("clv-auth-email");
      const passwordInput = document.getElementById("clv-auth-password");
      const submitBtn = document.getElementById("clv-auth-submit");
      const resetBtn = document.getElementById("clv-auth-reset");
      const signoutBtn = document.getElementById("clv-auth-signout");
      const statusEl = document.getElementById("clv-auth-status");
      const memberStatusEl = document.getElementById("clv-auth-member-status");
      const userNameEl = document.getElementById("clv-auth-user-name");
      const userEmailEl = document.getElementById("clv-auth-user-email");

      let mode = "signup";

      function setStatus(message, isError = false) {
        statusEl.textContent = message || "";
        statusEl.style.color = isError ? "#a6452a" : "#5a7772";
      }

      function setMemberStatus(message, isError = false) {
        memberStatusEl.textContent = message || "";
        memberStatusEl.style.color = isError ? "#a6452a" : "#5a7772";
      }

      function setMode(nextMode) {
        mode = nextMode;
        tabs.forEach((tab) => tab.classList.toggle("is-active", tab.dataset.authTab === nextMode));
        nameRow.classList.toggle("clv-auth-hidden", nextMode !== "signup");
        submitBtn.textContent = nextMode === "signup" ? "Create account" : "Sign in";
        passwordInput.autocomplete = nextMode === "signup" ? "new-password" : "current-password";
        setStatus("");
      }

      function refreshGateVisibility(isSignedIn) {
        document.querySelectorAll("[data-auth='guest']").forEach((el) => {
          el.classList.toggle("clv-auth-hidden", isSignedIn);
        });
        document.querySelectorAll("[data-auth='member']").forEach((el) => {
          el.classList.toggle("clv-auth-hidden", !isSignedIn);
        });
      }

      function setMemberUI(user) {
        const fullName = user?.user_metadata?.full_name || user?.email?.split("@")[0] || "Member";
        userNameEl.textContent = fullName;
        userEmailEl.textContent = user?.email || "";
        guestView.classList.toggle("clv-auth-hidden", !!user);
        memberView.classList.toggle("clv-auth-hidden", !user);
        refreshGateVisibility(!!user);
        window.dispatchEvent(new CustomEvent("collectividual:auth-state-changed", { detail: { user } }));
      }

      async function maybeCreateProfile(user, fullName) {
        if (!user) return;
        const payload = {
          id: user.id,
          email: user.email,
          full_name: fullName || user.user_metadata?.full_name || null
        };
        try {
          const { error } = await supabaseClient.from("profiles").upsert(payload, { onConflict: "id" });
          if (error) console.warn("Collectividual membership: profile upsert skipped.", error.message);
        } catch (error) {
          console.warn("Collectividual membership: profile table not available yet.", error);
        }
      }

      tabs.forEach((tab) => {
        tab.addEventListener("click", () => setMode(tab.dataset.authTab));
      });

      form.addEventListener("submit", async (event) => {
        event.preventDefault();
        setStatus("");
        const email = emailInput.value.trim();
        const password = passwordInput.value;
        const fullName = nameInput.value.trim();

        if (!email || !password) {
          setStatus("Email and password are required.", true);
          return;
        }

        try {
          if (mode === "signup") {
            const { data, error } = await supabaseClient.auth.signUp({
              email,
              password,
              options: {
                data: { full_name: fullName || null }
              }
            });
            if (error) throw error;
            await maybeCreateProfile(data.user, fullName);
            setStatus("Account created. Check your email if confirmation is enabled.");
          } else {
            const { data, error } = await supabaseClient.auth.signInWithPassword({
              email,
              password
            });
            if (error) throw error;
            setMemberUI(data.user);
            setStatus("");
          }
        } catch (error) {
          setStatus(error.message || "Something went wrong.", true);
        }
      });

      resetBtn.addEventListener("click", async () => {
        setStatus("");
        const email = emailInput.value.trim();
        if (!email) {
          setStatus("Enter your email first to send a reset link.", true);
          return;
        }
        try {
          const { error } = await supabaseClient.auth.resetPasswordForEmail(email);
          if (error) throw error;
          setStatus("Password reset email sent.");
        } catch (error) {
          setStatus(error.message || "Could not send reset email.", true);
        }
      });

      signoutBtn.addEventListener("click", async () => {
        setMemberStatus("");
        const { error } = await supabaseClient.auth.signOut();
        if (error) {
          setMemberStatus(error.message || "Could not sign out.", true);
          return;
        }
        setMemberUI(null);
        setMemberStatus("Signed out.");
      });

      supabaseClient.auth.onAuthStateChange((_event, session) => {
        setMemberUI(session?.user || null);
      });

      supabaseClient.auth.getSession().then(({ data }) => {
        setMemberUI(data.session?.user || null);
      });

      window.collectividualMembership = {
        getUser: async () => {
          const { data } = await supabaseClient.auth.getUser();
          return data.user || null;
        },
        signOut: async () => supabaseClient.auth.signOut()
      };

      setMode("signup");
    })();
  
    </script>
